# ============================================================================
# Reclaim Data — environment variables
# Copy to .env.local for local dev. All production values live in Render.
# ============================================================================

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (auth + database + storage) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_STORAGE_BUCKET=reclaimdata-uploads

# --- Anthropic (extraction) ------------------------------------------------
ANTHROPIC_API_KEY=

# --- Google Document AI (OCR fallback for low-quality scans) ---------------
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# --- Validators ------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ZEROBOUNCE_API_KEY=
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

# --- Email (Brevo, transactional only) -------------------------------------
BREVO_API_KEY=
BREVO_SENDER_EMAIL=hello@reclaimdata.ai
BREVO_SENDER_NAME=Reclaim Data

# --- Background jobs (Inngest) --------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Square (payments) ----------------------------------------------------
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
SQUARE_PLAN_ID_STARTER_MONTHLY=
SQUARE_PLAN_ID_PROFESSIONAL_MONTHLY=
SQUARE_PLAN_ID_LEGACY_MONTHLY=
SQUARE_PLAN_ID_STARTER_ANNUAL=
SQUARE_PLAN_ID_PROFESSIONAL_ANNUAL=
SQUARE_PLAN_ID_LEGACY_ANNUAL=

# --- Analytics & Errors ---------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
